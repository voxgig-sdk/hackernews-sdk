  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "description": "Represents a story, comment, job, Ask HN, poll, or poll option",
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "description": "The item's unique id"
          },
          "deleted": {
            "type": "boolean",
            "description": "true if the item is deleted"
          },
          "type": {
            "type": "string",
            "enum": [
              "job",
              "story",
              "comment",
              "poll",
              "pollopt"
            ],
            "description": "The type of item"
          },
          "by": {
            "type": "string",
            "description": "The username of the item's author"
          },
          "time": {
            "type": "integer",
            "description": "Creation date of the item, in Unix Time"
          },
          "text": {
            "type": "string",
            "description": "The comment, story or poll text. HTML."
          },
          "dead": {
            "type": "boolean",
            "description": "true if the item is dead"
          },
          "parent": {
            "type": "integer",
            "description": "The comment's parent: either another comment or the relevant story"
          },
          "poll": {
            "type": "integer",
            "description": "The pollopt's associated poll"
          },
          "kids": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "The ids of the item's comments, in ranked display order"
          },
          "url": {
            "type": "string",
            "description": "The URL of the story"
          },
          "score": {
            "type": "integer",
            "description": "The story's score, or the votes for a pollopt"
          },
          "title": {
            "type": "string",
            "description": "The title of the story, poll or job. HTML."
          },
          "parts": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "A list of related pollopts, in display order"
          },
          "descendants": {
            "type": "integer",
            "description": "In the case of stories or polls, the total comment count"
          }
        }
      },
      "User": {
        "type": "object",
        "description": "Represents a Hacker News user",
        "required": [
          "id",
          "created",
          "karma"
        ],
        "properties": {
          "id": {
            "type": "string",
            "description": "The user's unique username. Case-sensitive."
          },
          "created": {
            "type": "integer",
            "description": "Creation date of the user, in Unix Time"
          },
          "karma": {
            "type": "integer",
            "description": "The user's karma"
          },
          "about": {
            "type": "string",
            "description": "The user's optional self-description. HTML."
          },
          "submitted": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "List of the user's stories, polls and comments"
          }
        }
      },
      "Updates": {
        "type": "object",
        "description": "Contains lists of changed items and profiles",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "integer"
            },
            "description": "Array of item IDs that have been updated"
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Array of usernames whose profiles have been updated"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Items",
      "description": "Operations related to stories, comments, jobs, Ask HNs, and polls"
    },
    {
      "name": "Users",
      "description": "Operations related to user profiles"
    },
    {
      "name": "Stories",
      "description": "Operations to retrieve different story lists"
    },
    {
      "name": "Live Data",
      "description": "Operations to retrieve live data updates and metadata"
    }
  ],
  "externalDocs": {
    "description": "Official HackerNews API Documentation",
    "url": "https://github.com/HackerNews/API"
  }
}
