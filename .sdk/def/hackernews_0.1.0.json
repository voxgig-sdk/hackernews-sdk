            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "integer",
                  "description": "The current largest item ID"
                },
                "example": 9130260
              }
            }
          }
        }
      }
    },
